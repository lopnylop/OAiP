#include <iostream>
#include <cmath>
using namespace std;

int main() {
    double x, y;
    cout << "Введите x и y: ";
    cin >> x >> y;
    
    double r = sqrt(x * x + y * y);
    
    if (y > 0 && r < 3 && r < 3 && r > -3) 
    {
        cout << "В области" << endl;
        
    }
    
    else if (y < 0 || r > 3 || r > 3 || r < -3) 
    {
        cout << "Не в области" << endl;
    }

    else 
    {
        cout << "На границе" << endl;
    }

    return 0;
}  
